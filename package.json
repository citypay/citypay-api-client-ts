{
  "name": "citypay-api-ts-client",
  "version": "1.0.10-next",
  "description": "CityPay SDK client for citypay-api-ts-client",
  "author": "CityPay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/citypay/citypay-api-client-ts.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "prepare": "pnpm build",
    "test": "jest --testPathPatterns=./test/**/*.spec.ts"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.8",
    "dotenv": "^16.6.1",
    "jest": "^29.7.0",
    "mocha": "^10.8.2",
    "rimraf": "^5",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
